# Security
SECRET_KEY=change_this_to_a_secure_random_string_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# Database
# Use postgresql://user:password@db:5432/dbname for Docker Compose
DATABASE_URL=postgresql://aura_user:aura_password@db:5432/aura_db
# Or use SQLite for local testing:
# DATABASE_URL=sqlite:///./vibebuild.db

# Postgres Settings (Used to construct DATABASE_URL if not provided explicitly)
POSTGRES_SERVER=db
POSTGRES_USER=aura_user
POSTGRES_PASSWORD=aura_password
POSTGRES_DB=aura_db

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:5173", "http://localhost:80", "https://yourdomain.com"]

# AI Services
# ModelScope
MODELSCOPE_API_KEY=your_modelscope_api_key
MODELSCOPE_BASE_URL=https://api-inference.modelscope.cn/v1
MODELSCOPE_MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# DeepSeek (Optional)
USE_DEEPSEEK=True
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_NAME=deepseek-chat

# WeChat (Optional)
WECHAT_APP_ID=your_wx_appid
WECHAT_APP_SECRET=your_wx_secret
WECHAT_TOKEN=your_wx_token
